Moon_Brightness,Moon_Cycle,Phase_Num)
#Apartment
apt_sqm_data <- moon_with_mean |>
filter(Category == "Rock_Slide") |>
ungroup() |>
group_by(Date) |>
reframe(Date,Time,Category,Location,SQM,
Weather,Cloud_Cover,Humidity,
Moon_Brightness,Moon_Cycle,Phase_Num)
